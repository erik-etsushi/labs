cat >/opt/ssrf-lab/app/server.js <<'SERVER_JS'
const express = require('express');
const dns = require('dns').promises;
const net = require('net');
const { URL } = require('url');

const app = express();
const port = process.env.PORT || 8080;
const maxBytes = Number(process.env.MAX_RESPONSE_BYTES || 12000);

app.use(express.json());
app.use(express.static('public'));

function isPrivateOrSpecialIPv4(ip) {
  const parts = ip.split('.').map(Number);
  if (parts.length !== 4 || parts.some(n => Number.isNaN(n) || n < 0 || n > 255)) return true;
  const [a, b] = parts;
  return (
    a === 10 ||
    a === 127 ||
    (a === 169 && b === 254) ||
    (a === 172 && b >= 16 && b <= 31) ||
    (a === 192 && b === 168) ||
    a === 0 ||
    a >= 224
  );
}

function isPrivateOrSpecialIPv6(ip) {
  const normalized = ip.toLowerCase();
  return normalized === '::1' || normalized.startsWith('fe80:') || normalized.startsWith('fc') || normalized.startsWith('fd');
}

function isBlockedIp(ip) {
  const version = net.isIP(ip);
  if (version === 4) return isPrivateOrSpecialIPv4(ip);
  if (version === 6) return isPrivateOrSpecialIPv6(ip);
  return true;
}

async function validateUrlStrict(input) {
  const parsed = new URL(input);
  if (!['http:', 'https:'].includes(parsed.protocol)) {
    throw new Error('Only http and https are allowed');
  }
  if (parsed.username || parsed.password) {
    throw new Error('Credentials in URL are not allowed');
  }
  const records = await dns.lookup(parsed.hostname, { all: true, verbatim: true });
  if (!records.length) throw new Error('DNS resolution failed');
  for (const record of records) {
    if (isBlockedIp(record.address)) {
      throw new Error(`Blocked destination IP: ${record.address}`);
    }
  }
  return parsed.toString();
}

async function fetchWithLimit(url, options = {}) {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);
  try {
    const res = await fetch(url, {
      method: options.method || 'GET',
      headers: options.headers || {},
      redirect: options.redirect || 'follow',
      signal: controller.signal
    });
    const contentType = res.headers.get('content-type') || 'unknown';
    const reader = res.body.getReader();
    let received = 0;
    const chunks = [];
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      received += value.length;
      if (received > maxBytes) {
        chunks.push(value.slice(0, Math.max(0, value.length - (received - maxBytes))));
        break;
      }
      chunks.push(value);
    }
    const body = Buffer.concat(chunks).toString('utf8');
    return {
      status: res.status,
      contentType,
      truncated: received > maxBytes,
      body
    };
  } finally {
    clearTimeout(timeout);
  }
}

app.get('/health', (_req, res) => res.json({ ok: true }));

// Intentionally vulnerable endpoint for classroom demonstration only.
app.post('/api/fetch-vulnerable', async (req, res) => {
  const { url } = req.body || {};
  if (!url) return res.status(400).json({ error: 'Missing url' });
  try {
    const result = await fetchWithLimit(url, { redirect: 'follow' });
    res.json({ mode: 'vulnerable', requestedUrl: url, ...result });
  } catch (err) {
    res.status(502).json({ mode: 'vulnerable', error: err.message });
  }
});

// Safer endpoint: scheme restriction, DNS resolution checks, block private/link-local/loopback, no redirects.
app.post('/api/fetch-safe', async (req, res) => {
  const { url } = req.body || {};
  if (!url) return res.status(400).json({ error: 'Missing url' });
  try {
    const validated = await validateUrlStrict(url);
    const result = await fetchWithLimit(validated, { redirect: 'manual' });
    res.json({ mode: 'safe', requestedUrl: url, ...result });
  } catch (err) {
    res.status(400).json({ mode: 'safe', blocked: true, error: err.message });
  }
});

app.listen(port, () => {
  console.log(`SSRF lab listening on http://0.0.0.0:${port}`);
});

SERVER_JS
